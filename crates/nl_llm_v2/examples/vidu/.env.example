@echo off
REM 本文件仅作示例，不要提交包含真实密钥的 .env 文件。
REM 复制为 examples\vidu\.env 并填入你的 Vidu Key（该文件会被 .gitignore 忽略）。

REM 必填：你的 Vidu API Key
set VIDU_API_KEY=your_vidu_api_key_here

REM 可选：指定 Vidu API 域名
REM - 国内常用：https://api.vidu.cn
REM - 部分官方文档/示例：https://api.vidu.com
REM 若不设置，默认 https://api.vidu.cn
REM set VIDU_API_BASE_URL=https://api.vidu.cn

REM 可选：覆盖默认模型/参数（示例 vidu_video 会把这些写入 PrimitiveRequest.extra）
REM set VIDU_MODEL=viduq1
REM set VIDU_DURATION=5
REM set VIDU_RESOLUTION=1080p
REM set VIDU_MOVEMENT_AMPLITUDE=auto
REM set VIDU_BGM=false
REM set VIDU_OFF_PEAK=true
REM set VIDU_SEED=123

REM 可选：回调/透传 payload（便于联调）
REM set VIDU_CALLBACK_URL=https://example.com/callback
REM set VIDU_PAYLOAD=any_string_or_json
