# 本文件为示例配置（可提交）。
# 请复制为同目录下的 .env（不要提交），然后填入你的 VIDU_API_KEY。

# 必填：你的 Vidu API Key
VIDU_API_KEY=YOUR_VIDU_API_KEY_HERE

# 可选：切换 Vidu API 域名
# VIDU_API_BASE_URL=https://api.vidu.cn
# VIDU_API_BASE_URL=https://api.vidu.com

# 可选：默认参数（也可在运行时通过环境变量覆盖）
# VIDU_MODEL=viduq1
# VIDU_DURATION=5
# VIDU_RESOLUTION=1080p
# VIDU_MOVEMENT_AMPLITUDE=auto
# VIDU_BGM=false
# VIDU_SEED=123

# 可选：回调/透传 payload
# VIDU_CALLBACK_URL=
# VIDU_PAYLOAD=
