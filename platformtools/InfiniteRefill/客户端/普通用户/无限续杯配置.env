# 无限续杯配置（本地文件）
# 注意：请勿分享/上传此文件。
#
# 必填：
# - SERVER_URL：服务器地址，例如 https://127.0.0.1:8787
# - USER_KEY：用户密钥（USER_KEY 或 UPLOAD_KEY）
#
# 可选：
# - TARGET_POOL_SIZE：目标“可用账户数量”（默认 10；达标上传者可设 50）
# - TRIGGER_REMAINING：触发续杯阈值（失效后剩余 <= N 即触发；10账号默认 2 => 失效>=8）
# - INTERVAL_MINUTES：定时续杯间隔（分钟）
# - AUTO_REFILL_AFTER_CLEAN：清理后若不足配额，是否自动触发续杯（1=是；0=否）
# - AUTO_CLEAN_INTERVAL_MINUTES：自动清理间隔（分钟）
# - AUTO_CLEAN_APPLY：是否自动清理直接删除（1=删除；0=DryRun）
# - CLEAN_DELETE_STATUSES：自动清理删除状态码（逗号分隔，如 401,429,403）
# - SYNC_MODE：配置同步模式（none/copy/symlink）
# - SYNC_TARGET_DIR：配置同步目标目录（例如 C:\\Users\\you\\.cli-proxy-api）

SERVER_URL=
USER_KEY=
TARGET_POOL_SIZE=10
TRIGGER_REMAINING=2
INTERVAL_MINUTES=30
AUTO_REFILL_AFTER_CLEAN=0
AUTO_CLEAN_INTERVAL_MINUTES=30
AUTO_CLEAN_APPLY=0
CLEAN_DELETE_STATUSES=401,429,403
SYNC_MODE=none
SYNC_TARGET_DIR=

# 说明：
# - TRIGGER_REMAINING=2 等价于：10 个账号里 401+429 >= 8 就触发续杯
# - 如果你把 TARGET_POOL_SIZE 改成 50，可把 TRIGGER_REMAINING 改成 10（剩余<=10触发）
