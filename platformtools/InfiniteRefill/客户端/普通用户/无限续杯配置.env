# 无限续杯配置（统一模板）
# 注意：请勿分享/上传此文件（含密钥）。
# 服务端 /v1/refill/topup 响应会下发 total_hold_limit，客户端会自动回写 TOTAL_HOLD_LIMIT。

# ===== 基础连接 =====
SERVER_URL=https://refill.aiaimimi.com
USER_KEY=
ACCOUNTS_DIR=

# ===== 续杯触发参数 =====
TARGET_POOL_SIZE=10
TOTAL_HOLD_LIMIT=50

# ===== 自动任务参数（串行：先清理后续杯） =====
# 仅保留一个调度参数：每隔多少分钟执行一次
INTERVAL_MINUTES=30

# ===== 同步参数 =====
# 留空=不同步；填写目录=执行同步
SYNC_TARGET_DIR=
